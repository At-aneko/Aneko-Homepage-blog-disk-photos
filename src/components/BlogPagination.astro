---
interface Props {
  currentPage: number
  totalPages: number
}

const { currentPage, totalPages } = Astro.props

function pageUrl(page: number) {
  return page === 1 ? '/blog/' : `/blog/page/${page}/`
}
---

{totalPages > 1 && (
  <nav class="blogPagination" aria-label="文章分页">
    {currentPage > 1 ? (
      <a href={pageUrl(currentPage - 1)} aria-label="上一页">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
      </a>
    ) : (
      <span class="is-disabled" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"></path></svg>
      </span>
    )}

    <div>
      {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
        page === currentPage
          ? <span class="is-current" aria-current="page">{String(page).padStart(2, '0')}</span>
          : <a href={pageUrl(page)}>{String(page).padStart(2, '0')}</a>
      ))}
    </div>

    {currentPage < totalPages ? (
      <a href={pageUrl(currentPage + 1)} aria-label="下一页">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
      </a>
    ) : (
      <span class="is-disabled" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"></path></svg>
      </span>
    )}
  </nav>
)}
